# Demo recording (`bun run demo`) — optional.
# Set SEED_DEMO_PASSWORD to a strong random value and `bun run seed` will give
# the demo NGO + volunteer accounts a password they can sign in with, so the
# demo suite can film the claim → submit → approve → badge loop. Leave it blank
# and seeding skips those fixtures entirely.
# Pick a real random value: these accounts live on the same Appwrite project as
# the deployed site, and the NGO one can approve claims and mint badges.
SEED_DEMO_PASSWORD=
SEED_VOLUNTEER_EMAIL=
SEED_VOLUNTEER_NAME=
SEED_BADGE_LABEL=