{
  "name": "micromatch",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json --output human",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:demo": "DEMO=1 playwright test --config=playwright.demo.config.ts",
    "demo:gif": "bun run scripts/demos-to-gif.ts",
    "demo": "bun run test:demo && bun run demo:gif",
    "seed": "bun run scripts/seed.ts",
    "render-media": "bun run scripts/render-media.ts",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@dotlottie/player-component": "^2.7.12",
    "@iconify/svelte": "^5.2.2",
    "@smui/button": "^9.0.1",
    "@smui/card": "^9.0.1",
    "@smui/chips": "^9.0.1",
    "@smui/dialog": "^9.0.1",
    "@smui/fab": "^9.0.1",
    "@smui/icon-button": "^9.0.1",
    "@smui/linear-progress": "^9.0.1",
    "@smui/list": "^9.0.1",
    "@smui/snackbar": "^9.0.1",
    "@smui/textfield": "^9.0.1",
    "@smui/top-app-bar": "^9.0.1",
    "@sveltejs/kit": "^2.69.2",
    "@vercel/analytics": "^2.0.1",
    "appwrite": "^26.2.0",
    "canvas-confetti": "1.9.4",
    "mode-watcher": "^1.1.0",
    "node-appwrite": "^27.0.0",
    "svelte": "^5.56.4",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lottiefiles/lottie-types": "^1.5.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/canvas-confetti": "^1.9.0",
    "@types/howler": "^2.2.13",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "csstype": "^3.2.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
